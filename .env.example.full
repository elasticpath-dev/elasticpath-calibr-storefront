# ──────────────────────────────────────────────────────────────────────────
# Full reference — every environment variable the storefront reads.
#
# Start from .env.example.minimal instead if you just want to get running;
# come back to this file section by section as you need a specific feature.
# See README.md for the guided walkthrough.
# ──────────────────────────────────────────────────────────────────────────


# ── Elastic Path Commerce Cloud (required) ─────────────────────────────────
# Commerce Manager > Settings > Application Keys
# Endpoint: no "https://" prefix, no trailing slash
NEXT_PUBLIC_EPCC_ENDPOINT_URL=euwest.api.elasticpath.com
NEXT_PUBLIC_EPCC_CLIENT_ID=your-client-id

# Account Management password profile — needed for shopper login, sign-up,
# and password reset. Commerce Manager > Settings > Authentication > Password Profiles
NEXT_PUBLIC_PASSWORD_PROFILE_ID=your-password-profile-id

# OIDC SSO — comma-separated list of OIDC profile IDs from your EP authentication realm.
# Commerce Manager > Settings > Authentication > Single Sign-On.
# Leave empty to disable SSO buttons on the login form.
NEXT_PUBLIC_OIDC_PROFILE_IDS=

# Must match a currency your catalog's price book actually has prices in —
# if it doesn't, products will show blank/missing prices.
NEXT_PUBLIC_DEFAULT_CURRENCY=USD

# Set to true only if your store uses multi-location inventory — defaults to false
NEXT_PUBLIC_EP_INVENTORIES_MULTI_LOCATION=false

# Optional headers attached to every EPCC API request (server and client) —
# each is only sent when non-empty; leave blank to omit it entirely.
NEXT_PUBLIC_EP_CONTEXT_TAG=
NEXT_PUBLIC_ENVIRONMENT_ID=
NEXT_PUBLIC_STORE_ID=


# ── Elastic Path CMS (optional) ─────────────────────────────────────────────
# Leave both blank to disable — the storefront falls back to hard-coded
# homepage/footer/logo sections instead of CMS-managed content.
NEXT_PUBLIC_EP_CMS_PROJECT_ID=
NEXT_PUBLIC_EP_CMS_API_TOKEN=
# "true" = fetch the latest unpublished designs on every request (slow;
# useful only while actively authoring in the CMS studio).
# Leave unset/false in production to serve the published version from cache.
NEXT_PUBLIC_EP_CMS_PREVIEW=false


# ── Storefront password gate (optional) ─────────────────────────────────────
# Set a value to require a password before any page loads — useful for
# staging/preview links. Leave empty or remove to disable.
GATEKEEPER_PASSWORD=

# ── Require account login (optional) ────────────────────────────────────────
# "true" = no anonymous browsing — every page redirects to a sign-in gate
# until the shopper logs in (or signs up / uses SSO). Leave unset/false for
# normal storefront behavior (browse anonymously, log in only when needed).
REQUIRE_LOGIN=false

# Top navigation is cached in-memory per resolved catalog (see
# buildSiteNavigation in navigation.ts) — set this to a secret and call
# POST /api/navigation/clear-cache with `Authorization: Bearer <secret>` to
# manually purge it (e.g. after publishing a catalog change), rather than
# waiting for the server process to restart. Body is optional: omit it to
# clear everything, or send { catalogId, endpointUrl, storeId, environmentId }
# (the same values a cache entry was built from) to clear just that one entry.
NAV_CACHE_REVALIDATE_SECRET=


# ── Store branding (optional) ───────────────────────────────────────────────
# name is the wordmark shown in the header/checkout; title is the
# browser-tab/SEO title (defaults to "<name> by Elasticpath" if left blank).
NEXT_PUBLIC_STORE_NAME=Calibr
NEXT_PUBLIC_STORE_TITLE=
NEXT_PUBLIC_STORE_DESCRIPTION=

# ── Brand colors (optional — hex, no leading #) ─────────────────────────────
NEXT_PUBLIC_BRAND_PRIMARY=273a60
NEXT_PUBLIC_BRAND_SECONDARY=144e31
NEXT_PUBLIC_BRAND_ACCENT=56dc9b
NEXT_PUBLIC_BRAND_MUTED=666666

# ── Ink (neutral) scale (optional — hex, no leading #) ──────────────────────
NEXT_PUBLIC_COLOR_INK_900=0e1521
NEXT_PUBLIC_COLOR_INK_800=232c3a
NEXT_PUBLIC_COLOR_INK_700=3d4654
NEXT_PUBLIC_COLOR_INK_600=5c6675
NEXT_PUBLIC_COLOR_INK_400=8c95a3
NEXT_PUBLIC_COLOR_INK_300=c2c8d0
NEXT_PUBLIC_COLOR_INK_200=dde1e6
NEXT_PUBLIC_COLOR_INK_100=eef0f2
NEXT_PUBLIC_COLOR_INK_50=f7f8f9

# ── Semantic colors (optional — hex, no leading #) ──────────────────────────
NEXT_PUBLIC_COLOR_SUCCESS_600=18804c
NEXT_PUBLIC_COLOR_SUCCESS_500=21a765
NEXT_PUBLIC_COLOR_SUCCESS_400=2bcc7e
NEXT_PUBLIC_COLOR_ERROR_700=a8341f
NEXT_PUBLIC_COLOR_ERROR_600=c2402b
NEXT_PUBLIC_COLOR_WARNING_600=b26a00


# ── Layout (optional) ───────────────────────────────────────────────────────
# "true" = the whole storefront shell (header, footer, content, cart,
# checkout) spans 100% of the viewport width, and category/search grids show
# more cards per row. Leave unset/false for the default centered layout.
NEXT_PUBLIC_FULL_WIDTH=false


# ── Shopping preferences (optional) ─────────────────────────────────────────
# Default cart presentation: "drawer" (slide-in panel) or "full" (dedicated /cart page)
NEXT_PUBLIC_DEFAULT_CART_MODE=drawer

# Default shopping experience: "b2c" or "b2b". Shoppers can switch it
# themselves from the header settings drawer — this just sets the initial
# value. NOTE: if NEXT_PUBLIC_EPCC_ENDPOINT_URL contains "elasticpath.com"
# (an Elastic Path–hosted/SaaS store), shopping mode is always forced to
# "b2c" and the switcher is hidden, regardless of this setting.
NEXT_PUBLIC_DEFAULT_SHOPPING_MODE=b2c

# Default view mode for the B2B cart page: "list" or "grid"
NEXT_PUBLIC_CART_VIEW_MODE=list


# ── Currency (NEXT_PUBLIC_DEFAULT_CURRENCY is required — see above) ─────────
# Currencies shown in the header currency dropdown (comma-separated).
# Omit entirely for a single-currency store (no dropdown shown).
# Example: NEXT_PUBLIC_CURRENCIES=GBP,USD,CAD
NEXT_PUBLIC_CURRENCIES=


# ── Catalog search (optional) ───────────────────────────────────────────────
# Set to "true" to show the search icon and enable search
NEXT_PUBLIC_SEARCH_ENABLED=false

# Sidebar filter items for the search and category pages (requires
# NEXT_PUBLIC_SEARCH_ENABLED=true).
# Format: attribute|Display Name|type — comma-separated, one entry per filter
#   attribute    — field path as indexed (e.g. extensions.products(specification).brand)
#   Display Name — label shown in the sidebar
#   type         — checkbox (multi-select) | radio (toggle on/off)
# Example:
# NEXT_PUBLIC_FILTER_ITEMS=extensions.products(specification).brand|Brand|checkbox,extensions.products(specification).product-type|Product Type|checkbox
NEXT_PUBLIC_FILTER_ITEMS=

# Comma-separated extension group names to hide on the PDP (matches the
# name inside parentheses, e.g. extensions.products(highlights) -> "highlights")
NEXT_PUBLIC_EXTENSIONS_EXCLUDED=

# Set to "true" to hide catalog hierarchy roots from the top navigation and
# promote their direct children to top-level nav items instead (e.g. if
# "Tools" is a hierarchy with children "Hand Tools"/"Power Tools", the top
# nav shows "Hand Tools"/"Power Tools" directly rather than one "Tools" menu).
NEXT_PUBLIC_HIDE_NAV_HIERARCHY=false

# Where the desktop top navigation sits in the header: "inline" (centered
# between the logo and the action icons — the default), "below" (its own
# full-width row under the logo row, left-aligned) or "below-center" (same
# row, centered).
NEXT_PUBLIC_HEADER_NAV_POSITION=inline

# Desktop nav dropdown style: "mega" (multi-column mega menu — the default)
# or "cascade" (drill-down panel: click a top item to list its children in a
# column; click a child to open its children in a new column beside it).
# Navigation data itself can also come from Plasmic — if the Plasmic project
# contains a component named "navigation" it drives the top nav; otherwise
# the nav is built from the catalog. Layout/style always comes from these
# env vars either way.
NEXT_PUBLIC_NAV_STYLE=mega


# ── Payments (optional — required for the "Card" checkout option) ──────────
# If you're using EP Payments powered by Stripe, set your Stripe account ID —
# this also switches the payment gateway to Elastic Path's managed Stripe
# integration. If you're using your own Stripe account directly, leave the
# account ID blank and set only the publishable key.
NEXT_PUBLIC_STRIPE_ACCOUNT_ID=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Set to "true" to show PayPal as a checkout option. Requires the
# paypal_express_checkout gateway to be configured/enabled in Commerce
# Manager — no client-side key needed, EP handles the PayPal handshake.
NEXT_PUBLIC_PAYPAL_ENABLED=false


# ── Product analytics (optional) ────────────────────────────────────────────
# PostHog — leave the key empty to disable entirely (no script is loaded).
# Key:  PostHog project settings > Project API key
# Host: https://eu.i.posthog.com (default) or https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
